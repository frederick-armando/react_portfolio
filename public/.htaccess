<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # 1. Spécifier le fichier à servir par défaut dans les dossiers physiques
  DirectoryIndex index.html

  # 2. Ignorer la réécriture pour les fichiers et dossiers qui existent physiquement sur le serveur
  # Cela inclut le dossier /projets/ et ses sous-dossiers /projets/... générés par le script de postbuild.
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d

  # 3. Router toutes les autres requêtes (chemins virtuels de la SPA) vers l'index racine de React
  RewriteRule ^(.*)$ /index.html [L,QSA]
</IfModule>

<IfModule mod_headers.c>
  # Optionnel : S'assurer que les fichiers mis en cache ne posent pas de problèmes de versionning
  # Utile pendant les mises à jour fréquentes
  <FilesMatch "\.(html|htm)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires 0
  </FilesMatch>
</IfModule>
